generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String  @default("editor")
  isActive Boolean @default(true)

  campaigns Campaign[] @relation("UserCampaigns")
  auditLogs AuditLog[]

  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// CAMPAIGNS
//////////////////////////////////////////////////////

model Campaign {
  id Int @id @default(autoincrement())

  title       String
  description String?

  goal Int @default(100)

  status String @default("pendiente")
  // pendiente | activa | pausada | cerrada | rechazada

  type String @default("petition")
  // petition | email | both

  creatorName  String
  creatorEmail String

  imageUrl String?

  emailTarget String?

  editToken String @unique @default(uuid())

  createdById Int?
  createdBy   User? @relation("UserCampaigns", fields: [createdById], references: [id])

  participants Participant[]
  emailTargets EmailTarget[]
  emailLogs    EmailLog[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// PARTICIPANTS
//////////////////////////////////////////////////////

model Participant {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String
  email     String
  zipCode   String?

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  emailLogs EmailLog[]

  createdAt DateTime @default(now())

  @@index([campaignId])
}

//////////////////////////////////////////////////////
// EMAIL TARGETS
//////////////////////////////////////////////////////

model EmailTarget {
  id Int @id @default(autoincrement())

  name  String
  email String

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

//////////////////////////////////////////////////////
// EMAIL LOGS
//////////////////////////////////////////////////////

model EmailLog {
  id Int @id @default(autoincrement())

  participantId Int
  participant   Participant @relation(fields: [participantId], references: [id])

  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  sentAt DateTime @default(now())

  @@index([campaignId])
  @@index([participantId])
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id Int @id @default(autoincrement())

  action  String
  message String

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
}
